<script setup lang="ts">
import { ref, defineExpose } from 'vue'

const status = ref(false)

const open = () => {
  console.log('--- open() ---')
  status.value = true
  console.log('status', status.value)
}
const close = () => {
  console.log('--- close() ---')
  status.value = false
}

defineExpose({
  open,
  close
})
</script>

<template>
  <Teleport to="body">
    <div class="modal">
      <div class="modal__background">
        <div class="modal__content">
          <slot></slot>
        </div>
      </div>
    </div>
  </Teleport>
</template>

